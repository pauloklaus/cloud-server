# Base domain for Traefik Host rules / WireGuard SERVERURL (e.g. example.com)
DOMAIN=

CF_DNS_API_TOKEN=
ACME_EMAIL=

# WireGuard peer names (comma-separated). Keep real device names only in local .env
WG_PEERS=

# Public UDP port on the host (mapped to 51820 in the container; used in peer Endpoint)
WG_PORT=

# --- Network ranges (examples — change if they collide with your LAN) ---
# Avoid 172.17.0.0/16: that is Docker's default bridge (docker0).
# VPN tunnel (WireGuard peers). VPN_NETWORK is without mask (linuxserver INTERNAL_SUBNET).
VPN_SUBNET=172.18.0.0/24
VPN_NETWORK=172.18.0.0
VPN_GATEWAY=172.18.0.1

# Docker internal_services_net (AdGuard / WireGuard / Traefik fixed IPs)
SVC_SUBNET=172.19.0.0/24
ADGUARD_IP=172.19.0.2
WIREGUARD_IP=172.19.0.3
TRAEFIK_IP=172.19.0.10
